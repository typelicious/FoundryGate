#!/usr/bin/env bash
set -euo pipefail

# update code from repo + restart service
#
# Git operations run as the foundrygate service user (owner of /opt/foundrygate).
# systemd operations require sudo.
#
# Usage:
#   foundrygate-update          # normal update from any user with sudo rights
#   sudo -u foundrygate bash -c '/opt/foundrygate/scripts/foundrygate-update'  # explicit

FOUNDRYGATE_DIR=/opt/foundrygate
SERVICE_USER=foundrygate

# ── Git update ────────────────────────────────────────────────────────────────
# Run as the service user so .git/ metadata stays owned correctly.
if [ "$(id -un)" != "$SERVICE_USER" ] && command -v sudo >/dev/null 2>&1; then
  GIT_CMD="sudo -u $SERVICE_USER"
else
  GIT_CMD=""
fi

$GIT_CMD git -C "$FOUNDRYGATE_DIR" fetch --all --prune
$GIT_CMD git -C "$FOUNDRYGATE_DIR" reset --hard origin/main
$GIT_CMD git -C "$FOUNDRYGATE_DIR" clean -fd

# ── venv deps (optional) ──────────────────────────────────────────────────────
if [ -f "$FOUNDRYGATE_DIR/venv/bin/pip" ]; then
  $GIT_CMD "$FOUNDRYGATE_DIR/venv/bin/pip" install -U pip >/dev/null
  if [ -f "$FOUNDRYGATE_DIR/requirements.txt" ]; then
    $GIT_CMD "$FOUNDRYGATE_DIR/venv/bin/pip" install -r "$FOUNDRYGATE_DIR/requirements.txt"
  fi
fi

# ── systemd ───────────────────────────────────────────────────────────────────
sudo install -m 644 "$FOUNDRYGATE_DIR/foundrygate.service" /etc/systemd/system/foundrygate.service
sudo systemctl daemon-reload
sudo systemctl restart foundrygate.service

# ── health check ──────────────────────────────────────────────────────────────
for attempt in 1 2 3 4 5; do
  if "$FOUNDRYGATE_DIR/scripts/foundrygate-health"; then
    exit 0
  fi
  sleep 2
done

echo "health check failed after 5 attempts" >&2
exit 1
