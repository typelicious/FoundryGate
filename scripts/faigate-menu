    case "$choice" in
      1) run_config_wizard ;;
      2) run_client_wizard "openclaw" "general" ;;
      3) run_client_wizard "n8n" "free" ;;
      4) run_client_wizard "opencode" "coding" ;;
      5) run_client_wizard "cli" "general" ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

