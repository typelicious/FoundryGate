#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "${script_dir}/faigate-service-lib.sh"
source "${script_dir}/faigate-ui-lib.sh"

config_file="$(faigate_config_file)"
env_file="$(faigate_env_file)"
db_path="$(faigate_db_path)"
python_bin="$(faigate_python_bin)"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-menu

Interactive control center for fusionAIze Gate.

Env resolution:
  FAIGATE_CONFIG_FILE   config path
  FAIGATE_ENV_FILE      env path
  FAIGATE_PYTHON        python interpreter used by helper scripts
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

run_and_pause() {
  local command_rc=0
  echo ""
  "$@" || command_rc=$?
  echo ""
  if [ "$command_rc" -ne 0 ]; then
    faigate_ui_warn "Command exited with status ${command_rc}."
  fi
  faigate_ui_pause
  return 0
}

show_next_steps() {
  local title="$1"
  shift
  echo ""
  printf "  %bNext step%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "$title"
  for item in "$@"; do
    printf "    - %s\n" "$item"
  done
}

run_and_pause_with_receipt() {
  local title="$1"
  shift
  local step_count="$1"
  shift
  local -a steps=()
  local index
  for ((index = 0; index < step_count; index++)); do
    steps+=("$1")
    shift
  done

  local command_rc=0
  echo ""
  "$@" || command_rc=$?
  echo ""
  if [ "$command_rc" -ne 0 ]; then
    faigate_ui_warn "Command exited with status ${command_rc}."
  fi
  show_next_steps "$title" "${steps[@]}"
  faigate_ui_pause
  return 0
}

menu_snapshot() {
  FAIGATE_MENU_CONFIG="$config_file" FAIGATE_MENU_ENV="$env_file" "$python_bin" - <<'PY'
from pathlib import Path
import os
import re

import yaml

config_path = Path(os.environ["FAIGATE_MENU_CONFIG"])
env_path = Path(os.environ["FAIGATE_MENU_ENV"])
raw = {}
if config_path.exists():
    with config_path.open(encoding="utf-8") as handle:
        raw = yaml.safe_load(handle) or {}

env_values = {}
if env_path.exists():
    for line in env_path.read_text(encoding="utf-8").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, value = stripped.split("=", 1)
        env_values[key.strip()] = value.strip().strip('"').strip("'")

providers = raw.get("providers") or {}
fallback_chain = raw.get("fallback_chain") or []
routing = raw.get("routing_modes") or {}
client_profiles = raw.get("client_profiles") or {}
profiles = (client_profiles.get("profiles") or {}) if isinstance(client_profiles, dict) else {}
presets = (client_profiles.get("presets") or []) if isinstance(client_profiles, dict) else []
providers_ready = 0
providers_missing_keys = 0

for payload in providers.values():
    if not isinstance(payload, dict):
        continue
    api_key = payload.get("api_key")
    if isinstance(api_key, str):
        match = re.fullmatch(r"\$\{([^}:]+)(?::-[^}]*)?\}", api_key.strip())
        if match:
            if env_values.get(match.group(1), ""):
                providers_ready += 1
            else:
                providers_missing_keys += 1
            continue
    providers_ready += 1

default_profile = (
    client_profiles.get("default", "generic") if isinstance(client_profiles, dict) else "generic"
)
next_client = ""
priority = ["opencode", "openclaw", "n8n", "cli"]
if default_profile in priority:
    next_client = default_profile
else:
    available_client_targets = set(priority) & (set(profiles) | set(presets))
    for item in priority:
        if item in available_client_targets:
            next_client = item
            break

preset_summary = "none yet"
if len(presets) == 1:
    preset_summary = "1 active"
elif len(presets) > 1:
    preset_summary = f"{len(presets)} active"

print(f"providers={len(providers)}")
print(f"providers_ready={providers_ready}")
print(f"providers_missing_keys={providers_missing_keys}")
print(f"fallbacks={len(fallback_chain)}")
print(f"default_mode={routing.get('default', 'auto')}")
print(f"default_profile={default_profile}")
print(f"profiles={len(profiles)}")
print(f"presets={len(presets)}")
print(f"preset_summary={preset_summary}")
print(f"next_client={next_client or 'none'}")
PY
}

collect_runtime_snapshot() {
  local state health_state bind snapshot_output line providers_count providers_ready providers_missing_keys
  local fallback_count default_mode default_profile profile_count preset_count
  local preset_summary next_client
  state="$(faigate_service_state)"
  if faigate_is_healthy; then
    health_state="healthy"
  else
    health_state="unreachable"
  fi
  bind="$(faigate_host):$(faigate_port)"
  snapshot_output="$(menu_snapshot)"
  providers_count="0"
  providers_ready="0"
  providers_missing_keys="0"
  fallback_count="0"
  default_mode="auto"
  default_profile="generic"
  profile_count="0"
  preset_count="0"
  while IFS= read -r line; do
    case "$line" in
      providers=*) providers_count="${line#providers=}" ;;
      providers_ready=*) providers_ready="${line#providers_ready=}" ;;
      providers_missing_keys=*) providers_missing_keys="${line#providers_missing_keys=}" ;;
      fallbacks=*) fallback_count="${line#fallbacks=}" ;;
      default_mode=*) default_mode="${line#default_mode=}" ;;
      default_profile=*) default_profile="${line#default_profile=}" ;;
      profiles=*) profile_count="${line#profiles=}" ;;
      presets=*) preset_count="${line#presets=}" ;;
      preset_summary=*) preset_summary="${line#preset_summary=}" ;;
      next_client=*) next_client="${line#next_client=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  printf 'state=%s\n' "$state"
  printf 'health=%s\n' "$health_state"
  printf 'bind=%s\n' "$bind"
  printf 'providers=%s\n' "$providers_count"
  printf 'providers_ready=%s\n' "$providers_ready"
  printf 'providers_missing_keys=%s\n' "$providers_missing_keys"
  printf 'fallbacks=%s\n' "$fallback_count"
  printf 'default_mode=%s\n' "$default_mode"
  printf 'default_profile=%s\n' "$default_profile"
  printf 'profiles=%s\n' "$profile_count"
  printf 'presets=%s\n' "$preset_count"
  printf 'preset_summary=%s\n' "${preset_summary:-none yet}"
  printf 'next_client=%s\n' "${next_client:-none}"
}

render_summary_cards() {
  local snapshot_output line state health_state bind providers_count providers_ready providers_missing_keys
  local fallback_count default_mode default_profile profile_count preset_count preset_summary next_client
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      state=*) state="${line#state=}" ;;
      health=*) health_state="${line#health=}" ;;
      bind=*) bind="${line#bind=}" ;;
      providers=*) providers_count="${line#providers=}" ;;
      providers_ready=*) providers_ready="${line#providers_ready=}" ;;
      providers_missing_keys=*) providers_missing_keys="${line#providers_missing_keys=}" ;;
      fallbacks=*) fallback_count="${line#fallbacks=}" ;;
      default_mode=*) default_mode="${line#default_mode=}" ;;
      default_profile=*) default_profile="${line#default_profile=}" ;;
      profiles=*) profile_count="${line#profiles=}" ;;
      presets=*) preset_count="${line#presets=}" ;;
      preset_summary=*) preset_summary="${line#preset_summary=}" ;;
      next_client=*) next_client="${line#next_client=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  printf "  %bGateway%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Service" "$state"
  printf "  %-18s %s\n" "Health" "$health_state"
  printf "  %-18s %s\n" "Bind" "$bind"
  echo ""
  printf "  %bConfig%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Default mode" "$default_mode"
  printf "  %-18s %s\n" "Config" "$config_file"
  printf "  %-18s %s\n" "Env" "$env_file"
  echo ""
  printf "  %bProviders%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Configured" "$providers_count"
  printf "  %-18s %s\n" "Ready" "$providers_ready"
  printf "  %-18s %s\n" "Missing keys" "$providers_missing_keys"
  printf "  %-18s %s\n" "Fallbacks" "$fallback_count"
  echo ""
  printf "  %bClients%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Default profile" "$default_profile"
  printf "  %-18s %s\n" "Profiles" "$profile_count"
  printf "  %-18s %s\n" "Preset matches" "${preset_summary:-none yet}"
  if [ -n "${next_client:-}" ] && [ "${next_client}" != "none" ]; then
    printf "  %-18s %s\n" "Best next step" "$next_client"
  fi
  printf "\n"
}

best_next_client() {
  local snapshot_output line next_client
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      next_client=*) next_client="${line#next_client=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF
  if [ -n "${next_client:-}" ] && [ "$next_client" != "none" ]; then
    printf "%s\n" "$next_client"
  fi
}

render_quick_setup_guidance() {
  local snapshot_output line health_state providers_count providers_ready providers_missing_keys
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      health=*) health_state="${line#health=}" ;;
      providers=*) providers_count="${line#providers=}" ;;
      providers_ready=*) providers_ready="${line#providers_ready=}" ;;
      providers_missing_keys=*) providers_missing_keys="${line#providers_missing_keys=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  if [ "${providers_count:-0}" = "0" ]; then
    faigate_ui_tip "Start with API Keys if you already know your providers, then run Full Config Wizard to generate the first usable config."
  elif [ "${providers_missing_keys:-0}" != "0" ] || [ "${providers_ready:-0}" = "0" ]; then
    faigate_ui_tip "Some configured providers are still missing API keys. Fill the env file first, then rerun Validate."
  elif [ "${health_state:-unreachable}" != "healthy" ]; then
    faigate_ui_tip "Config looks close. Restart + Verify is the next best step so the gateway can pick up the current config."
  else
    faigate_ui_tip "The gateway looks ready. Open Client Quickstarts next and wire in the first client."
  fi
}

show_status_overview() {
  local version host port log_level health_state
  version="$("$python_bin" -m faigate --version 2>/dev/null || echo "faigate unknown")"
  host="$(faigate_host)"
  port="$(faigate_port)"
  log_level="$(faigate_log_level)"
  if curl -fsS -m 2 "$(faigate_health_url)" >/dev/null 2>&1; then
    health_state="healthy"
  else
    health_state="unreachable"
  fi

  faigate_ui_header "fusionAIze Gate Status" "Standalone control center"
  printf "  %-18s %s\n" "Version" "$version"
  printf "  %-18s %s\n" "Config" "$config_file"
  printf "  %-18s %s\n" "Env" "$env_file"
  printf "  %-18s %s\n" "Database" "$db_path"
  printf "  %-18s %s\n" "Bind" "${host}:${port}"
  printf "  %-18s %s\n" "Log level" "$log_level"
  printf "  %-18s %s\n" "Health" "$health_state"
}

show_models() {
  local models_url payload
  models_url="$(faigate_models_url)"
  if ! payload="$(curl -fsS -m 2 "$models_url")"; then
    faigate_ui_error "Model list is not reachable at ${models_url}."
    return 1
  fi

  FAIGATE_MODELS_PAYLOAD="$payload" "$python_bin" - <<'PY'
import json
import os

data = json.loads(os.environ["FAIGATE_MODELS_PAYLOAD"])
models = [item.get("id", "") for item in data.get("data", []) if item.get("id")]

print(f"Exposed models: {len(models)}")
for idx, model in enumerate(models, start=1):
    marker = " (recommended default)" if model == "auto" else ""
    print(f"{idx:>2}. {model}{marker}")
PY
}

run_config_wizard() {
  local purpose_in purpose client selection apply_mode backup_suffix
  local -a cmd_args

  faigate_ui_header "fusionAIze Gate Config Wizard" "Providers, routing modes, client profiles"
  printf "  %bPurpose%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(1=general  2=coding  3=quality  4=free)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ [general]: "
  read -r purpose_in
  case "${purpose_in:-1}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
    1|general|"") purpose="general" ;;
    2|coding) purpose="coding" ;;
    3|quality) purpose="quality" ;;
    4|free) purpose="free" ;;
    *) purpose="general" ;;
  esac

  echo ""
  printf "  %bClient profile%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(generic | openclaw | n8n | cli | opencode)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ [generic]: "
  read -r client
  case "${client:-generic}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
    ""|generic|openclaw|n8n|cli|opencode) client="${client:-generic}" ;;
    *) client="generic" ;;
  esac

  echo ""
  faigate_ui_info "Fetching provider candidates for purpose=${purpose} client=${client}..."
  echo ""
  FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
    bash "${script_dir}/faigate-config-wizard" \
      --env-file "$env_file" \
      --purpose "$purpose" \
      --client "$client" \
      --current-config "$config_file" \
      --text-candidates \
      --list-candidates || true

  echo ""
  printf "  %bSelect providers%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(comma-separated IDs, 'all', Enter = recommendations)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ Selection: "
  read -r selection
  case "$selection" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  echo ""
  printf "  %bApply mode%b\n" "$FAIGATE_UI_BOLD"
  printf "    1)  Dry-run only    Preview changes, no writes\n"
  printf "    2)  Write config    Update config.yaml (backup created automatically)\n"
  printf "    c)  Cancel\n"
  printf "    q)  Quit\n"
  printf "  ▸ [1]: "
  read -r apply_mode
  case "${apply_mode:-1}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  cmd_args=(--env-file "$env_file" --purpose "$purpose" --client "$client")
  if [ -f "$config_file" ]; then
    cmd_args+=(--current-config "$config_file" --merge-existing)
    if [ "${apply_mode:-1}" = "2" ]; then
      cmd_args+=(--apply recommended_add,recommended_replace,recommended_mode_changes)
    fi
  fi
  if [ -n "$selection" ] && [ "$selection" != "all" ]; then
    cmd_args+=(--select "$selection")
  fi

  if [ "${apply_mode:-1}" = "2" ]; then
    backup_suffix=".before-wizard-$(date +%Y%m%d%H%M%S)"
    cmd_args+=(--write "$config_file" --write-backup --backup-suffix "$backup_suffix")
    run_and_pause_with_receipt "Wizard wrote the config." 3 \
      "Restart + Verify to load the new config." \
      "Run Validate if you changed providers or routing defaults." \
      "Open Clients when you want the first consumer wired in." \
      env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}"
    printf "  Restart fusionAIze Gate to apply changes? [y/N]: "
    read -r restart_choice
    if [[ "${restart_choice:-N}" =~ ^[Yy]$ ]]; then
      run_and_pause_with_receipt "Gateway restart completed." 3 \
        "Run Health Check to confirm the active runtime." \
        "Open Status if you want the manager and bound port details." \
        "Open Clients to connect the first workflow or coding tool." \
        bash "${script_dir}/faigate-restart"
    fi
  else
    cmd_args+=(--dry-run-summary)
    run_and_pause_with_receipt "Dry-run completed." 3 \
      "Write config when the provider set and mode changes look right." \
      "Update API Keys first if the suggested providers are not ready yet." \
      "Use Validate after writing changes to catch missing pieces early." \
      env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}"
  fi
}

run_client_wizard() {
  local client="$1"
  local purpose="${2:-general}"
  local selection apply_mode backup_suffix
  local -a cmd_args

  faigate_ui_header "fusionAIze Gate Client Wizard" "Scoped to client profile: ${client}"
  faigate_ui_info "Fetching provider candidates for purpose=${purpose} client=${client}..."
  echo ""
  FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
    bash "${script_dir}/faigate-config-wizard" \
      --env-file "$env_file" \
      --purpose "$purpose" \
      --client "$client" \
      --current-config "$config_file" \
      --text-candidates \
      --list-candidates || true

  echo ""
  printf "  %bSelect providers%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(comma-separated IDs, 'all', Enter = recommendations)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ Selection: "
  read -r selection
  case "$selection" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  echo ""
  printf "  %bApply mode%b\n" "$FAIGATE_UI_BOLD"
  printf "    1)  Dry-run only    Preview changes, no writes\n"
  printf "    2)  Write config    Update config.yaml (backup created automatically)\n"
  printf "    c)  Cancel\n"
  printf "    q)  Quit\n"
  printf "  ▸ [1]: "
  read -r apply_mode
  case "${apply_mode:-1}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  cmd_args=(
    --env-file "$env_file"
    --purpose "$purpose"
    --client "$client"
    --current-config "$config_file"
    --merge-existing
  )
  if [ "${apply_mode:-1}" = "2" ]; then
    cmd_args+=(--apply recommended_add,recommended_replace,recommended_mode_changes)
    cmd_args+=(--select-profiles "$client")
  fi
  if [ -n "$selection" ] && [ "$selection" != "all" ]; then
    cmd_args+=(--select "$selection")
  fi

  if [ "${apply_mode:-1}" = "2" ]; then
    backup_suffix=".client-${client}-$(date +%Y%m%d%H%M%S)"
    cmd_args+=(--write "$config_file" --write-backup --backup-suffix "$backup_suffix")
    run_and_pause_with_receipt "Client-scoped config update completed." 3 \
      "Restart + Verify to activate the new client default." \
      "Use Client Matrix to confirm the profile and match intent." \
      "Use the client drilldown to grab the exact setup hints again." \
      env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}"
  else
    cmd_args+=(--dry-run-summary)
    run_and_pause_with_receipt "Client-scoped dry-run completed." 3 \
      "Write config when the client-specific routing change looks right." \
      "Check Client Matrix if you want to confirm the current profile posture." \
      "Run the matching client drilldown for copyable setup details." \
      env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}"
  fi
}

status_menu() {
  while true; do
    show_status_overview
    echo ""
    render_summary_cards
    faigate_ui_tip "Use Service Status when you want the raw manager output and bound listener details."
    echo ""
    printf "    1)  Service Status   Detailed service/runtime status\n"
    printf "    2)  Health Check     Query /health\n"
    printf "    3)  Models           List exposed model ids\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-status" ;;
      2) run_and_pause bash "${script_dir}/faigate-health" ;;
      3) run_and_pause show_models ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

quick_setup_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Quick Setup" "Fastest path from first keys to first healthy client"
    render_summary_cards
    render_quick_setup_guidance
    echo ""
    printf "    1)  API Keys           Set provider keys in the env file\n"
    printf "    2)  Full Config Wizard Generate or update the main config\n"
    printf "    3)  Validate           Run doctor checks against the current config\n"
    printf "    4)  Restart + Verify   Restart the gateway and wait for /health\n"
    printf "    5)  Client Quickstarts Show client-specific next steps\n"
    printf "    6)  Current Config     Review the current config snapshot\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause_with_receipt "API keys updated." 3 \
        "Run Full Config Wizard when providers are still missing from config.yaml." \
        "Run Validate next to confirm provider env coverage." \
        "Restart + Verify only after config and env are both where you want them." \
        bash "${script_dir}/faigate-api-keys" ;;
      2) run_config_wizard ;;
      3) run_and_pause_with_receipt "Validation completed." 3 \
        "Fix any missing env or endpoint warnings before restart work." \
        "Restart + Verify once the doctor output is clean enough." \
        "Open Client Quickstarts when the gateway looks healthy." \
        bash "${script_dir}/faigate-doctor" ;;
      4) run_and_pause_with_receipt "Gateway restart completed." 3 \
        "Run Health Check if you want the live runtime summary again." \
        "Open Status when you need service-manager and listener details." \
        "Open Client Quickstarts to connect the first real client." \
        bash "${script_dir}/faigate-restart" ;;
      5) run_and_pause_with_receipt "Client quickstarts loaded." 3 \
        "Open one client drilldown when you want copyable details for exactly one tool." \
        "Use a client-scoped wizard when one client needs a tuned routing default." \
        "Return to Quick Setup when you want the shortest path again." \
        bash "${script_dir}/faigate-client-integrations" --recommended ;;
      6) run_and_pause bash "${script_dir}/faigate-config-overview" ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

configure_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Configure" "Config, providers, and local gateway settings"
    render_summary_cards
    faigate_ui_tip "Use Guided Setup for provider/client recommendations. Use Direct Settings when you already know the exact values to change."
    echo ""
    printf "    1)  Current Config   Snapshot of bind settings, providers, modes, and profiles\n"
    printf "    2)  Guided Setup     Wizard-led provider and client-profile flows\n"
    printf "    3)  Direct Settings  API keys, HTTP settings, and routing defaults\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-config-overview" ;;
      2) configure_guided_menu ;;
      3) configure_direct_menu ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

configure_guided_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Guided Setup" "Wizard-led flows similar to the later Grid orchestration model"
