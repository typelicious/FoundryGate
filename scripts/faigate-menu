clients_menu() {
  local next_client
  while true; do
    faigate_ui_header "fusionAIze Gate Clients" "Client quickstarts, matrix, and client-scoped wizard flows"
    next_client="$(best_next_client || true)"
    if [ -n "${next_client:-}" ]; then
      faigate_ui_tip "Best next step: open ${next_client} Details, then use the ${next_client} Wizard if that client needs its own default."
    else
      faigate_ui_tip "Start with recommended client cards for a compact view. Use one-client drilldowns when you want copyable details without the long cross-client dump."
    fi
    echo ""
    printf "    1)  Recommended Cards  Compact client recommendations\n"
    printf "    2)  Client Matrix      Show active client profiles and match intent\n"
    printf "    3)  OpenClaw Details   Drill into OpenClaw setup hints\n"
    printf "    4)  n8n Details        Drill into n8n setup hints\n"
    printf "    5)  opencode Details   Drill into opencode setup hints\n"
    printf "    6)  CLI Details        Drill into generic CLI setup hints\n"
    printf "    7)  All Quickstarts    Show the full client quickstart list\n"
    printf "    8)  OpenClaw Wizard    Run a client-scoped wizard for OpenClaw\n"
    printf "    9)  n8n Wizard         Run a client-scoped wizard for n8n\n"
    printf "   10)  opencode Wizard    Run a client-scoped wizard for opencode\n"
    printf "   11)  CLI Wizard         Run a client-scoped wizard for cli callers\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-client-integrations" --recommended ;;
      2) run_and_pause bash "${script_dir}/faigate-client-integrations" --matrix ;;
      3) run_and_pause bash "${script_dir}/faigate-client-integrations" --client openclaw ;;
      4) run_and_pause bash "${script_dir}/faigate-client-integrations" --client n8n ;;
      5) run_and_pause bash "${script_dir}/faigate-client-integrations" --client opencode ;;
      6) run_and_pause bash "${script_dir}/faigate-client-integrations" --client cli ;;
      7) run_and_pause bash "${script_dir}/faigate-client-integrations" ;;
      8) run_client_wizard "openclaw" "general" ;;
      9) run_client_wizard "n8n" "free" ;;
      10) run_client_wizard "opencode" "coding" ;;
      11) run_client_wizard "cli" "general" ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

validate_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Validate" "Operational validation helpers"
    faigate_ui_tip "Doctor is best for fast local checks. Onboarding Report is better when you want a fuller operator handoff view."
    echo ""
    printf "    1)  Doctor               Validate config, env, and local endpoints\n"
    printf "    2)  Onboarding Report    Human-readable rollout summary\n"
    printf "    3)  Onboarding Validate  Structured blockers and warnings\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause_with_receipt "Doctor completed." 3 \
        "Address missing env or endpoint warnings before restart work." \
        "Open Onboarding Report when you want the fuller operator handoff view." \
        "Restart + Verify once the local checks look clean enough." \
        bash "${script_dir}/faigate-doctor" ;;
      2) run_and_pause_with_receipt "Onboarding report rendered." 3 \
        "Use Onboarding Validate for blocker/warning output you can act on." \
        "Open Client Quickstarts if you want the next integration hints only." \
        "Return to Configure when the report shows obvious provider or profile gaps." \
        bash "${script_dir}/faigate-onboarding-report" ;;
      3) run_and_pause_with_receipt "Onboarding validation completed." 3 \
        "Resolve blockers before treating the gateway as production-ready." \
        "Use Doctor for a tighter local operator check after fixes." \
        "Restart + Verify when config or env changes just landed." \
        bash "${script_dir}/faigate-onboarding-validate" ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

control_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Control" "Start, stop, restart, status, and logs"
    render_summary_cards
    faigate_ui_tip "Use Service Overview before restart work, and prefer Recent Logs before jumping into a live tail."
    echo ""
    printf "    1)  Service Overview   Manager, paths, bind target, and raw status\n"
    printf "    2)  Start              Start the service through the active manager\n"
    printf "    3)  Stop               Stop the service through the active manager\n"
    printf "    4)  Restart + Verify   Restart and wait for /health to recover\n"
    printf "    5)  Recent Logs        Print the latest service logs and return\n"
    printf "    6)  Tail Logs          Follow service logs live\n"
    printf "    7)  Health Check       Query /health directly\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-status" ;;
      2) run_and_pause bash "${script_dir}/faigate-start" ;;
      3) run_and_pause bash "${script_dir}/faigate-stop" ;;
      4) run_and_pause_with_receipt "Restart + Verify completed." 3 \
        "Run Health Check if you want the compact runtime summary." \
        "Open Recent Logs when the service recovered but behavior still looks odd." \
        "Go to Clients when the gateway is healthy and ready to connect tools." \
        bash "${script_dir}/faigate-restart" ;;
      5) run_and_pause bash "${script_dir}/faigate-logs" --lines 80 ;;
      6) run_and_pause bash "${script_dir}/faigate-logs" --follow ;;
      7) run_and_pause bash "${script_dir}/faigate-health" ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

update_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Update" "Release checks and guarded auto-update flows"
    faigate_ui_tip "Check Updates is read-only. Apply Auto-update should stay the last step after status, health, and log review all look clean."
    echo ""
    printf "    1)  Check Updates        Query /api/update\n"
    printf "    2)  Auto-update Status   Eligibility and guardrails\n"
    printf "    3)  Apply Auto-update    Run the guarded apply path\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-update-check" ;;
      2) run_and_pause bash "${script_dir}/faigate-auto-update" ;;
      3)
        printf "  Apply auto-update now? [y/N]: "
        read -r confirm
        if [[ "${confirm:-N}" =~ ^[Yy]$ ]]; then
          run_and_pause bash "${script_dir}/faigate-auto-update" --apply
        fi
        ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

while true; do
  faigate_ui_header "fusionAIze Gate Control Center" "Standalone operations menu"
  render_summary_cards
  faigate_ui_tip "A good default path is Quick Setup -> Validate -> Clients."
  echo ""
  printf "    1)  Quick Setup  Guided path from API keys to first healthy client\n"
  printf "    2)  Status       Version, paths, service state, and models\n"
  printf "    3)  Configure    Wizard, API keys, HTTP settings, routing modes\n"
  printf "    4)  Clients      Quickstarts, matrix, and client-scoped wizard flows\n"
  printf "    5)  Explore      Provider discovery and exposed models\n"
  printf "    6)  Validate     Doctor, onboarding report, validation\n"
  printf "    7)  Control      Start, stop, restart, status, logs\n"
  printf "    8)  Update       Release checks and auto-update flows\n"
  printf "\n"
  printf "    q)  Quit\n\n"
  printf "  ▸ Choice: "
  read -r choice
  case "$choice" in
    1) quick_setup_menu ;;
    2) status_menu ;;
    3) configure_menu ;;
    4) clients_menu ;;
    5) explore_menu ;;
    6) validate_menu ;;
    7) control_menu ;;
    8) update_menu ;;
    q|Q) exit 0 ;;
    *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
  esac
done
