    printf "    1)  Full Config Wizard   Providers, routing modes, and client profiles\n"
    printf "    2)  OpenClaw Wizard      Client-scoped wizard for OpenClaw\n"
    printf "    3)  n8n Wizard           Client-scoped wizard for n8n\n"
    printf "    4)  opencode Wizard      Client-scoped wizard for opencode\n"
    printf "    5)  CLI Wizard           Client-scoped wizard for cli callers\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
