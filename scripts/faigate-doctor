#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"

case "${1:-}" in
  --help|-h)
    cat <<'EOF'
Usage:
  ./scripts/faigate-doctor

Run local operator checks for config/env presence, provider env coverage,
catalog alerts, and reachability of /health and /v1/models.
EOF
    exit 0
    ;;
esac

env_file="$(faigate_env_file)"
config_file="$(faigate_config_file)"
python_bin="$(faigate_python_bin)"
status=0

export FAIGATE_ENV_FILE="$env_file"
export FAIGATE_CONFIG_FILE="$config_file"
health_payload=""

ok() {
  printf '[ok] %s\n' "$1"
}

warn() {
  printf '[warn] %s\n' "$1"
}

fail() {
  printf '[fail] %s\n' "$1" >&2
  status=1
}

if [ -f "$config_file" ]; then
  ok "config present: $config_file"
else
  fail "missing config file: $config_file"
fi

if [ -f "$env_file" ]; then
  ok "env file present: $env_file"
else
  fail "missing env file: $env_file"
fi

db_path="$(faigate_db_path)"

db_dir="$(dirname "$db_path")"
if [ -d "$db_dir" ] && [ -w "$db_dir" ]; then
  ok "db directory is writable: $db_dir"
elif [ -d "$db_dir" ]; then
  warn "db directory exists but is not writable by $(id -un): $db_dir"
else
  warn "db directory does not exist yet: $db_dir"
fi

if [ -f "$env_file" ] && grep -Eq '^(DEEPSEEK_API_KEY|GEMINI_API_KEY|OPENROUTER_API_KEY|OPENAI_API_KEY|ANTHROPIC_API_KEY|OPENCODE_API_KEY|BLACKBOX_API_KEY|KILOCODE_API_KEY)=[^[:space:]#]+' "$env_file"; then
  ok "at least one provider API key is configured"
else
  warn "no provider API key detected in $env_file"
fi

if command -v curl >/dev/null 2>&1; then
  if payload="$(curl -fsS -m 2 "$(faigate_health_url)" 2>/dev/null)"; then
    health_payload="$payload"
  fi
fi

export FAIGATE_HEALTH_PAYLOAD="$health_payload"

if ! "$python_bin" - <<'PY'
import os
import sys
import json
from pathlib import Path

import yaml
from faigate.onboarding import collect_provider_env_requirements
from faigate.provider_catalog import build_provider_catalog_report
from faigate.config import ConfigError, load_config
from faigate.lane_registry import (
    get_canonical_model_routes,
    get_provider_lane_binding,
    get_route_add_recommendations,
)

config_path = Path(os.environ.get("FAIGATE_CONFIG_FILE", ""))
raw_config = {}
if config_path.exists():
    raw_config = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}

if isinstance(raw_config, dict) and raw_config.get("suggestions"):
    print(
        "[warn] config appears to contain wizard suggestions alongside runtime config; "
        "restore a clean config backup if summary keys like purpose/client/suggestions were written accidentally"
    )

requirements = collect_provider_env_requirements(
    config_path=os.environ.get("FAIGATE_CONFIG_FILE"),
    env_file=os.environ.get("FAIGATE_ENV_FILE"),
)

for name in requirements["present"]:
    print(f"[ok] provider env present: {name}")
for name in requirements["missing"]:
    print(f"[warn] provider env missing: {name}")

try:
    config = load_config(os.environ.get("FAIGATE_CONFIG_FILE"))
except ConfigError as exc:
    print(f"[fail] config invalid: {exc}")
    sys.exit(1)
configured_provider_names = set(config.providers.keys())

catalog = build_provider_catalog_report(config)
if catalog["alert_count"] == 0:
    print("[ok] provider catalog shows no model-drift or freshness alerts")
else:
    for alert in catalog["alerts"]:
        print(f"[warn] provider catalog: {alert['message']}")

policy = catalog.get("recommendation_policy", {})
print(
    "[ok] provider discovery policy: provider links affect ranking = "
    f"{policy.get('provider_links_affect_ranking', False)}"
)
for item in catalog.get("items", []):
    discovery = item.get("discovery") or {}
    resolved = discovery.get("resolved_url")
    if not resolved:
        continue
    label = "disclosed link" if discovery.get("disclosure_required") else "official link"
    print(f"[ok] provider discovery: {item['provider']} -> {label} -> {resolved}")

health_raw = os.environ.get("FAIGATE_HEALTH_PAYLOAD", "").strip()
if health_raw:
    health_payload = json.loads(health_raw)
    providers = (health_payload.get("providers") or {})
    ready = 0
    total = 0
    action_counts = {
        "fix-now": 0,
        "hold": 0,
        "watch": 0,
        "route": 0,
        "inspect": 0,
    }
    recommendation_counts = {
        "same-lane-route": 0,
        "cluster-degrade": 0,
        "family-route": 0,
        "none": 0,
    }
    add_counts = {
        "same-lane-add": 0,
        "cluster-add": 0,
        "family-add": 0,
        "none": 0,
    }
    rows = []
    mirror_gap_routes = 0

    def classify_action(
        *,
        status: str,
        ready: bool,
        cooldown_active: bool,
        window_state: str,
        recovered_recently: bool,
    ) -> str:
        if status in {
            "missing-key",
            "unresolved-key",
            "auth-invalid",
            "endpoint-mismatch",
            "model-unavailable",
        }:
            return "fix-now"
        if cooldown_active or window_state == "cooldown" or status in {"quota-exhausted", "rate-limited"}:
            return "hold"
        if recovered_recently or window_state == "degraded" or status == "ready-recovered":
            return "watch"
        if ready or status in {"ready", "ready-verified", "ready-compat"}:
            return "route"
        return "inspect"

    for provider_name, payload in sorted(providers.items()):
        total += 1
        request_readiness = payload.get("request_readiness") or {}
        if not request_readiness:
            continue
        status = str(request_readiness.get("status") or "unknown")
        reason = str(request_readiness.get("reason") or "no request-readiness detail")
        profile = str(request_readiness.get("profile") or "")
        compatibility = str(request_readiness.get("compatibility") or "")
        confidence = str(request_readiness.get("probe_confidence") or "")
        verified_via = str(request_readiness.get("verified_via") or "")
        probe_payload = str(request_readiness.get("probe_payload") or "")
        operator_hint = str(request_readiness.get("operator_hint") or "")
        runtime_penalty = int(request_readiness.get("runtime_penalty") or 0)
        runtime_issue_type = str(request_readiness.get("runtime_issue_type") or "")
        cooldown_active = bool(request_readiness.get("runtime_cooldown_active"))
        runtime_window_state = str(request_readiness.get("runtime_window_state") or "clear")
        runtime_cooldown_remaining = int(request_readiness.get("runtime_cooldown_remaining_s") or 0)
        runtime_degraded_remaining = int(request_readiness.get("runtime_degraded_remaining_s") or 0)
        runtime_recovered_recently = bool(request_readiness.get("runtime_recovered_recently"))
        runtime_recovery_remaining = int(request_readiness.get("runtime_recovery_remaining_s") or 0)
        runtime_last_recovered_issue = str(
            request_readiness.get("runtime_last_recovered_issue_type") or ""
        )
        lane = dict(get_provider_lane_binding(provider_name))
        lane.update(payload.get("lane") or {})
        family = str(lane.get("family") or "")
        action_group = classify_action(
            status=status,
            ready=bool(request_readiness.get("ready")),
            cooldown_active=cooldown_active,
            window_state=runtime_window_state,
            recovered_recently=runtime_recovered_recently,
        )
        action_counts[action_group] += 1
        canonical_model = str(lane.get("canonical_model") or "")
        known_routes = get_canonical_model_routes(canonical_model) if canonical_model else []
        known_mirror_gaps = [
            str(route.get("provider_name") or "")
            for route in known_routes
            if str(route.get("provider_name") or "")
            and str(route.get("provider_name") or "") != provider_name
            and str(route.get("provider_name") or "") not in configured_provider_names
        ]
        if known_mirror_gaps:
            mirror_gap_routes += 1
        lane_cluster = str(lane.get("cluster") or "")
        degrade_to = [str(item) for item in (lane.get("degrade_to") or []) if str(item)]
        add_recommendations = get_route_add_recommendations(
            configured_provider_names=configured_provider_names,
            canonical_model=canonical_model,
            degrade_to=degrade_to,
            family=family,
        )
        rows.append(
            {
                "provider": provider_name,
                "family": family or "unclassified",
                "canonical_model": canonical_model,
                "lane_cluster": lane_cluster,
                "freshness_status": str(lane.get("freshness_status") or ""),
                "review_age_days": int(lane.get("review_age_days") or -1),
                "freshness_hint": str(lane.get("freshness_hint") or ""),
                "degrade_to": degrade_to,
                "known_mirror_gaps": known_mirror_gaps,
                "add_recommendations": add_recommendations,
                "action": action_group,
                "ready": bool(request_readiness.get("ready")),
                "status": status,
                "reason": reason,
                "profile": profile,
                "compatibility": compatibility,
                "confidence": confidence,
                "verified_via": verified_via,
                "probe_payload": probe_payload,
                "operator_hint": operator_hint,
                "runtime_penalty": runtime_penalty,
                "runtime_issue_type": runtime_issue_type,
                "cooldown_active": cooldown_active,
                "runtime_window_state": runtime_window_state,
                "runtime_cooldown_remaining": runtime_cooldown_remaining,
                "runtime_degraded_remaining": runtime_degraded_remaining,
                "runtime_recovered_recently": runtime_recovered_recently,
                "runtime_recovery_remaining": runtime_recovery_remaining,
                "runtime_last_recovered_issue": runtime_last_recovered_issue,
            }
        )

    def pick_recommendation(current_row):
        if current_row["action"] == "route":
            return "", "none"
        candidates = [
            row
            for row in rows
            if row["provider"] != current_row["provider"] and row["action"] in {"route", "watch"}
        ]
        candidates.sort(key=lambda row: (0 if row["action"] == "route" else 1, row["provider"]))
        if current_row["canonical_model"]:
            for candidate in candidates:
                if candidate["canonical_model"] == current_row["canonical_model"]:
                    return candidate["provider"], "same-lane-route"
        for candidate in candidates:
            if candidate["canonical_model"] in current_row["degrade_to"]:
                return candidate["provider"], "cluster-degrade"
        for candidate in candidates:
            if candidate["family"] == current_row["family"]:
                return candidate["provider"], "family-route"
        return "", "none"

    for row in rows:
        profile_bits = []
        if row["profile"]:
            profile_bits.append(row["profile"])
        if row["compatibility"]:
            profile_bits.append(row["compatibility"])
        if row["confidence"]:
            profile_bits.append(f"confidence={row['confidence']}")
        if row["verified_via"]:
            profile_bits.append(f"verified={row['verified_via']}")
        profile_suffix = f" [{' | '.join(profile_bits)}]" if profile_bits else ""
        if row["ready"]:
            ready += 1
            print(
                f"[ok] request-ready: {row['provider']} -> {row['status']}{profile_suffix} "
                f"({row['reason']})"
            )
        else:
            print(
                f"[warn] request-ready: {row['provider']} -> {row['status']}{profile_suffix} "
                f"({row['reason']})"
            )
        details = [row["family"]]
        if row["canonical_model"]:
            details.append(row["canonical_model"])
        if row["lane_cluster"]:
            details.append(row["lane_cluster"])
        if row["freshness_status"]:
            details.append(f"freshness={row['freshness_status']}")
        print(
            f"[ok] request-ready action: {row['provider']} -> {row['action']} "
            f"[{' | '.join(details)}]"
        )
        if row["review_age_days"] >= 0 or row["freshness_hint"]:
            freshness_bits = []
            if row["review_age_days"] >= 0:
                freshness_bits.append(f"review_age={row['review_age_days']}d")
            if row["freshness_hint"]:
                freshness_bits.append(row["freshness_hint"])
            print(
                f"[ok] request-ready freshness: {row['provider']} -> "
                + " | ".join(freshness_bits)
            )
        if row["probe_payload"]:
            print(f"[ok] request-ready payload: {row['provider']} -> {row['probe_payload']}")
        if row["operator_hint"]:
            print(f"[ok] request-ready next step: {row['provider']} -> {row['operator_hint']}")
        if row["runtime_penalty"] or row["runtime_issue_type"]:
            cooldown_suffix = " | cooldown active" if row["cooldown_active"] else ""
            window_suffix = ""
            if row["runtime_window_state"] == "cooldown" and row["runtime_cooldown_remaining"]:
                window_suffix = f" | cooldown {row['runtime_cooldown_remaining']}s left"
            elif row["runtime_window_state"] == "degraded" and row["runtime_degraded_remaining"]:
                window_suffix = f" | degraded {row['runtime_degraded_remaining']}s left"
            print(
                f"[ok] request-ready runtime: {row['provider']} -> penalty={row['runtime_penalty']}"
                f" | issue={row['runtime_issue_type'] or 'n/a'}{cooldown_suffix}{window_suffix}"
            )
        if row["runtime_recovered_recently"]:
            print(
                f"[ok] request-ready recovery: {row['provider']} -> recovered from "
                f"{row['runtime_last_recovered_issue'] or 'n/a'} | watch "
                f"{row['runtime_recovery_remaining']}s"
            )
        if row["known_mirror_gaps"]:
            print(
                f"[ok] request-ready mirror gap: {row['provider']} -> "
                + ", ".join(row["known_mirror_gaps"][:3])
            )
        add_recommendations = row["add_recommendations"]
        if add_recommendations:
            top_add = add_recommendations[0]
            add_strategy = str(top_add.get("strategy") or "route-addition")
            add_counts[add_strategy] = add_counts.get(add_strategy, 0) + 1
            print(
                f"[ok] request-ready add route: {row['provider']} -> "
                f"{top_add.get('provider_name')} ({add_strategy})"
            )
        preferred_route, strategy = pick_recommendation(row)
        recommendation_counts[strategy] = recommendation_counts.get(strategy, 0) + 1
        if preferred_route:
            print(
                f"[ok] request-ready preferred route: {row['provider']} -> {preferred_route} "
                f"({strategy})"
            )
    if total:
        print(f"[ok] request readiness summary: {ready}/{total} provider routes look request-ready")
        print(
            "[ok] request-ready actions: "
            f"fix-now={action_counts['fix-now']} | hold={action_counts['hold']} | "
            f"watch={action_counts['watch']} | route={action_counts['route']} | "
            f"inspect={action_counts['inspect']}"
        )
        print(
            "[ok] request-ready fallback guidance: "
            f"same-lane={recommendation_counts['same-lane-route']} | "
            f"cluster={recommendation_counts['cluster-degrade']} | "
            f"family={recommendation_counts['family-route']}"
        )
        print(
            "[ok] request-ready add guidance: "
            f"same-lane={add_counts['same-lane-add']} | "
            f"cluster={add_counts['cluster-add']} | "
            f"family={add_counts['family-add']}"
        )
        print(
            f"[ok] request-ready mirror gaps: {mirror_gap_routes} routes have known mirrors not configured"
        )
PY
then
  status=1
fi

if command -v curl >/dev/null 2>&1; then
  if curl -fsS -m 2 "$(faigate_health_url)" >/dev/null 2>&1; then
    ok "local /health endpoint is reachable"
  else
    warn "local /health endpoint is not reachable on $(faigate_local_host):$(faigate_port)"
  fi

  if curl -fsS -m 2 "$(faigate_models_url)" >/dev/null 2>&1; then
    ok "local /v1/models endpoint is reachable"
  else
    warn "local /v1/models endpoint is not reachable on $(faigate_local_host):$(faigate_port)"
  fi
else
  warn "curl is not available; skipping local endpoint checks"
fi

exit "$status"
