#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"

case "${1:-}" in
  --help|-h)
    cat <<'EOF'
Usage:
  ./scripts/faigate-doctor

Run local operator checks for config/env presence, provider env coverage,
catalog alerts, and reachability of /health and /v1/models.
EOF
    exit 0
    ;;
esac

env_file="$(faigate_env_file)"
config_file="$(faigate_config_file)"
python_bin="$(faigate_python_bin)"
status=0

export FAIGATE_ENV_FILE="$env_file"
export FAIGATE_CONFIG_FILE="$config_file"

ok() {
  printf '[ok] %s\n' "$1"
}

warn() {
  printf '[warn] %s\n' "$1"
}

fail() {
  printf '[fail] %s\n' "$1" >&2
  status=1
}

if [ -f "$config_file" ]; then
  ok "config present: $config_file"
else
  fail "missing config file: $config_file"
fi

if [ -f "$env_file" ]; then
  ok "env file present: $env_file"
else
  fail "missing env file: $env_file"
fi

db_path="$(faigate_db_path)"

db_dir="$(dirname "$db_path")"
if [ -d "$db_dir" ] && [ -w "$db_dir" ]; then
  ok "db directory is writable: $db_dir"
elif [ -d "$db_dir" ]; then
  warn "db directory exists but is not writable by $(id -un): $db_dir"
else
  warn "db directory does not exist yet: $db_dir"
fi

if [ -f "$env_file" ] && grep -Eq '^(DEEPSEEK_API_KEY|GEMINI_API_KEY|OPENROUTER_API_KEY|OPENAI_API_KEY|ANTHROPIC_API_KEY|OPENCODE_API_KEY)=[^[:space:]#]+' "$env_file"; then
  ok "at least one provider API key is configured"
else
  warn "no provider API key detected in $env_file"
fi

"$python_bin" - <<'PY'
import os
from pathlib import Path

import yaml
from faigate.onboarding import collect_provider_env_requirements
from faigate.provider_catalog import build_provider_catalog_report
from faigate.config import load_config

config_path = Path(os.environ.get("FAIGATE_CONFIG_FILE", ""))
raw_config = {}
if config_path.exists():
    raw_config = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}

if isinstance(raw_config, dict) and raw_config.get("suggestions"):
    print(
        "[warn] config appears to contain wizard suggestions alongside runtime config; "
        "restore a clean config backup if summary keys like purpose/client/suggestions were written accidentally"
    )

requirements = collect_provider_env_requirements(
    config_path=os.environ.get("FAIGATE_CONFIG_FILE"),
    env_file=os.environ.get("FAIGATE_ENV_FILE"),
)

for name in requirements["present"]:
    print(f"[ok] provider env present: {name}")
for name in requirements["missing"]:
    print(f"[warn] provider env missing: {name}")

config = load_config(os.environ.get("FAIGATE_CONFIG_FILE"))
catalog = build_provider_catalog_report(config)
if catalog["alert_count"] == 0:
    print("[ok] provider catalog shows no model-drift or freshness alerts")
else:
    for alert in catalog["alerts"]:
        print(f"[warn] provider catalog: {alert['message']}")

policy = catalog.get("recommendation_policy", {})
print(
    "[ok] provider discovery policy: provider links affect ranking = "
    f"{policy.get('provider_links_affect_ranking', False)}"
)
for item in catalog.get("items", []):
    discovery = item.get("discovery") or {}
    resolved = discovery.get("resolved_url")
    if not resolved:
        continue
    label = "disclosed link" if discovery.get("disclosure_required") else "official link"
    print(f"[ok] provider discovery: {item['provider']} -> {label} -> {resolved}")
PY

if command -v curl >/dev/null 2>&1; then
  if curl -fsS -m 2 "$(faigate_health_url)" >/dev/null 2>&1; then
    ok "local /health endpoint is reachable"
  else
    warn "local /health endpoint is not reachable on $(faigate_local_host):$(faigate_port)"
  fi

  if curl -fsS -m 2 "$(faigate_models_url)" >/dev/null 2>&1; then
    ok "local /v1/models endpoint is reachable"
  else
    warn "local /v1/models endpoint is not reachable on $(faigate_local_host):$(faigate_port)"
  fi
else
  warn "curl is not available; skipping local endpoint checks"
fi

exit "$status"
