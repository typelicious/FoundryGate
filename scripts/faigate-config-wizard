#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${FAIGATE_ENV_FILE:-$repo_root/.env}"
python_bin="${FAIGATE_PYTHON:-python3}"
purpose="general"
client="generic"
format="yaml"
text_candidates="false"
current_config=""
merge_existing="false"
list_candidates="false"
write_path=""
selected_csv=""
apply_groups_csv=""
profile_csv=""
dry_run_summary="false"
write_backup="false"
backup_suffix=".bak"

print_help() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-config-wizard [options]

Purpose-aware setup:
  --purpose <general|coding|quality|free>
  --client <generic|openclaw|n8n|cli|opencode|custom>
  --env-file <path>
  --json | --yaml

Candidate review:
  --list-candidates
  --text-candidates   Compact text cards for interactive review

Existing config review:
  --current-config <path>
  --merge-existing
  --dry-run-summary

Selection and apply flow:
  --select provider-a,provider-b
  --select-profiles n8n,opencode
  --apply recommended_add,recommended_replace,recommended_mode_changes

Write controls:
  --write <path>
  --write-backup
  --backup-suffix <suffix>

Examples:
  ./scripts/faigate-config-wizard --purpose general --client generic > config.yaml
  ./scripts/faigate-config-wizard --purpose free --client n8n --list-candidates
  ./scripts/faigate-config-wizard --current-config config.yaml --purpose free --client n8n
  ./scripts/faigate-config-wizard --current-config config.yaml --purpose free --client n8n \
    --apply recommended_add,recommended_replace,recommended_mode_changes \
    --select kilocode,openrouter-fallback --select-profiles n8n --dry-run-summary
  ./scripts/faigate-config-wizard --current-config config.yaml --purpose free --client n8n \
    --apply recommended_add,recommended_replace,recommended_mode_changes \
    --select kilocode,openrouter-fallback --select-profiles n8n \
    --write config.yaml --write-backup --backup-suffix .before-wizard

Tip:
  Run with --current-config and no --select first to inspect
  recommended_add / recommended_replace / recommended_keep /
  recommended_mode_changes before writing anything.
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --help|-h)
      print_help
      exit 0
      ;;
    --env-file)
      env_file="$2"
      shift 2
      ;;
    --purpose)
      purpose="$2"
      shift 2
      ;;
    --client)
      client="$2"
      shift 2
      ;;
    --select)
      if [ -n "$selected_csv" ]; then
        selected_csv="${selected_csv},$2"
      else
        selected_csv="$2"
      fi
      shift 2
      ;;
    --select-profiles)
      if [ -n "$profile_csv" ]; then
        profile_csv="${profile_csv},$2"
      else
        profile_csv="$2"
      fi
      shift 2
      ;;
    --apply)
      if [ -n "$apply_groups_csv" ]; then
        apply_groups_csv="${apply_groups_csv},$2"
      else
        apply_groups_csv="$2"
      fi
      shift 2
      ;;
    --dry-run-summary)
      dry_run_summary="true"
      shift
      ;;
    --write-backup)
      write_backup="true"
      shift
      ;;
    --backup-suffix)
      backup_suffix="$2"
      shift 2
      ;;
    --current-config)
      current_config="$2"
      shift 2
      ;;
    --text-candidates)
      text_candidates="true"
      shift
      ;;
    --merge-existing)
      merge_existing="true"
      shift
      ;;
    --list-candidates)
      list_candidates="true"
      shift
      ;;
    --write)
      write_path="$2"
      shift 2
      ;;
    --json)
      format="json"
      shift
      ;;
    --yaml)
      format="yaml"
      shift
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

export FAIGATE_WIZARD_ENV="$env_file"
export FAIGATE_WIZARD_PURPOSE="$purpose"
export FAIGATE_WIZARD_CLIENT="$client"
export FAIGATE_WIZARD_FORMAT="$format"
export FAIGATE_WIZARD_TEXT_CANDIDATES="$text_candidates"
export FAIGATE_WIZARD_CURRENT_CONFIG="$current_config"
export FAIGATE_WIZARD_MERGE_EXISTING="$merge_existing"
export FAIGATE_WIZARD_LIST_CANDIDATES="$list_candidates"
export FAIGATE_WIZARD_WRITE_PATH="$write_path"
export FAIGATE_WIZARD_SELECTED="$selected_csv"
export FAIGATE_WIZARD_APPLY_GROUPS="$apply_groups_csv"
export FAIGATE_WIZARD_SELECTED_PROFILES="$profile_csv"
export FAIGATE_WIZARD_DRY_RUN_SUMMARY="$dry_run_summary"
export FAIGATE_WIZARD_WRITE_BACKUP="$write_backup"
export FAIGATE_WIZARD_BACKUP_SUFFIX="$backup_suffix"

"$python_bin" - <<'PY'
import json
import os
from pathlib import Path

import yaml

from faigate.wizard import (
    apply_update_suggestions,
    build_config_change_summary,
    build_initial_config,
    render_candidate_cards_text,
    build_update_suggestions,
    list_provider_candidates,
    merge_initial_config,
    write_output_file,
)

env_file = os.environ["FAIGATE_WIZARD_ENV"]
purpose = os.environ["FAIGATE_WIZARD_PURPOSE"]
client = os.environ["FAIGATE_WIZARD_CLIENT"]
render_format = os.environ["FAIGATE_WIZARD_FORMAT"]
text_candidates = os.environ["FAIGATE_WIZARD_TEXT_CANDIDATES"] == "true"
current_config = os.environ["FAIGATE_WIZARD_CURRENT_CONFIG"] or None
merge_existing = os.environ["FAIGATE_WIZARD_MERGE_EXISTING"] == "true"
list_candidates_only = os.environ["FAIGATE_WIZARD_LIST_CANDIDATES"] == "true"
write_path = os.environ["FAIGATE_WIZARD_WRITE_PATH"] or None
selected_raw = os.environ["FAIGATE_WIZARD_SELECTED"]
selected = [item.strip() for item in selected_raw.split(",") if item.strip()]
apply_groups_raw = os.environ["FAIGATE_WIZARD_APPLY_GROUPS"]
apply_groups = [item.strip() for item in apply_groups_raw.split(",") if item.strip()]
selected_profiles_raw = os.environ["FAIGATE_WIZARD_SELECTED_PROFILES"]
selected_profiles = [item.strip() for item in selected_profiles_raw.split(",") if item.strip()]
dry_run_summary = os.environ["FAIGATE_WIZARD_DRY_RUN_SUMMARY"] == "true"
write_backup = os.environ["FAIGATE_WIZARD_WRITE_BACKUP"] == "true"
backup_suffix = os.environ["FAIGATE_WIZARD_BACKUP_SUFFIX"]

if list_candidates_only:
    if text_candidates:
        rendered = render_candidate_cards_text(
            env_file=env_file,
            purpose=purpose,
            client=client,
            config_path=current_config,
        )
    else:
        payload = {
            "purpose": purpose,
            "client": client,
            "candidates": list_provider_candidates(
                env_file=env_file,
                purpose=purpose,
                client=client,
                config_path=current_config,
            ),
        }
        rendered = (
            json.dumps(payload, indent=2)
            if render_format == "json"
            else yaml.safe_dump(payload, sort_keys=False, allow_unicode=False)
        )
elif current_config is not None and not selected:
    payload = {
        "purpose": purpose,
        "client": client,
        "suggestions": build_update_suggestions(
            env_file=env_file,
            purpose=purpose,
            client=client,
            config_path=current_config,
        ),
    }
    rendered = (
        json.dumps(payload, indent=2)
        if render_format == "json"
        else yaml.safe_dump(payload, sort_keys=False, allow_unicode=False)
    )
elif current_config is not None and apply_groups:
    payload = apply_update_suggestions(
        env_file=env_file,
        purpose=purpose,
        client=client,
        config_path=current_config,
        apply_groups=apply_groups,
        selected_providers=selected or None,
        selected_profiles=selected_profiles or None,
    )
    if dry_run_summary:
        payload = build_config_change_summary(
            config_path=current_config,
            updated_config=payload,
        )
    rendered = (
        json.dumps(payload, indent=2)
        if render_format == "json"
        else yaml.safe_dump(payload, sort_keys=False, allow_unicode=False)
    )
else:
    suggestion = build_initial_config(
        env_file=env_file,
        purpose=purpose,
        client=client,
        selected_providers=selected or None,
    )
    payload = (
        merge_initial_config(config_path=current_config, suggestion=suggestion)
        if merge_existing and current_config is not None
        else suggestion
    )
    if dry_run_summary and current_config is not None:
        payload = build_config_change_summary(
            config_path=current_config,
            updated_config=payload,
        )
    rendered = (
        json.dumps(payload, indent=2)
        if render_format == "json"
        else yaml.safe_dump(payload, sort_keys=False, allow_unicode=False)
    )

if write_path:
    write_output_file(
        output_path=write_path,
        rendered=rendered,
        write_backup=write_backup,
        backup_suffix=backup_suffix,
    )
else:
    print(rendered, end="" if rendered.endswith("\n") else "\n")
PY
