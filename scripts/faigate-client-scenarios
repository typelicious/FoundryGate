#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-ui-lib.sh"

config_file="$(faigate_config_file)"
env_file="$(faigate_env_file)"
python_bin="$(faigate_python_bin)"
mode="interactive"
scenario_id=""
interactive_choice="0"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-client-scenarios
  ./scripts/faigate-client-scenarios --text
  ./scripts/faigate-client-scenarios --json
  ./scripts/faigate-client-scenarios --scenario ID --apply
  ./scripts/faigate-client-scenarios --interactive

Review or apply named client scenario templates such as:
  opencode-eco
  opencode-balanced
  opencode-quality
  opencode-free
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --text)
      mode="text"
      shift
      ;;
    --json)
      mode="json"
      shift
      ;;
    --scenario)
      scenario_id="${2:-}"
      shift 2
      ;;
    --apply)
      mode="apply"
      shift
      ;;
    --interactive)
      mode="interactive"
      interactive_choice="1"
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

show_next_steps() {
  local title="$1"
  shift
  echo ""
  printf "  %bNext step%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "$title"
  for item in "$@"; do
    printf "    - %s\n" "$item"
  done
}

scenario_client_name() {
  local scenario="$1"
  case "$scenario" in
    opencode-*) printf "opencode" ;;
    openclaw-*) printf "openclaw" ;;
    n8n-*) printf "n8n" ;;
    cli-*) printf "cli" ;;
    *) printf "" ;;
  esac
}

render_scenarios() {
  FAIGATE_SCENARIO_CONFIG="$config_file" \
    FAIGATE_SCENARIO_ENV="$env_file" \
    FAIGATE_SCENARIO_MODE="$1" \
    "$python_bin" - <<'PY'
import json
import os

from faigate.wizard import list_client_scenarios, render_client_scenarios_text

if os.environ["FAIGATE_SCENARIO_MODE"] == "json":
    print(
        json.dumps(
            list_client_scenarios(
                env_file=os.environ["FAIGATE_SCENARIO_ENV"],
                config_path=os.environ["FAIGATE_SCENARIO_CONFIG"],
            ),
            indent=2,
            sort_keys=True,
        )
    )
else:
    print(
        render_client_scenarios_text(
            env_file=os.environ["FAIGATE_SCENARIO_ENV"],
            config_path=os.environ["FAIGATE_SCENARIO_CONFIG"],
        ),
        end="",
    )
PY
}

list_scenario_ids() {
  FAIGATE_SCENARIO_CONFIG="$config_file" \
    FAIGATE_SCENARIO_ENV="$env_file" \
    "$python_bin" - <<'PY'
from faigate.wizard import list_client_scenarios
import os

for item in list_client_scenarios(
    env_file=os.environ["FAIGATE_SCENARIO_ENV"],
    config_path=os.environ["FAIGATE_SCENARIO_CONFIG"],
):
    print(f"{item['id']}\t{item['title']}\t{item['budget_posture']}")
PY
}

apply_scenario() {
  local scenario="$1"
  local write_mode="$2"
  FAIGATE_SCENARIO_ID="$scenario" \
    FAIGATE_SCENARIO_CONFIG="$config_file" \
    FAIGATE_SCENARIO_ENV="$env_file" \
    FAIGATE_SCENARIO_WRITE="$write_mode" \
    "$python_bin" - <<'PY'
import os
from pathlib import Path

import yaml

from faigate.wizard import apply_client_scenario, render_client_scenario_summary

payload = apply_client_scenario(
    scenario_id=os.environ["FAIGATE_SCENARIO_ID"],
    config_path=os.environ["FAIGATE_SCENARIO_CONFIG"],
    env_file=os.environ.get("FAIGATE_SCENARIO_ENV") or None,
)
print(render_client_scenario_summary(payload), end="")
if os.environ["FAIGATE_SCENARIO_WRITE"] == "write":
    Path(os.environ["FAIGATE_SCENARIO_CONFIG"]).write_text(
        yaml.safe_dump(payload["config"], sort_keys=False, allow_unicode=False),
        encoding="utf-8",
    )
PY
}

if [[ "$mode" == "text" || "$mode" == "json" ]]; then
  render_scenarios "$mode"
  exit 0
fi

if [[ "$mode" == "apply" ]]; then
  if [[ -z "$scenario_id" ]]; then
    echo "Missing --scenario ID" >&2
    exit 2
  fi
  apply_scenario "$scenario_id" "write"
  exit 0
fi

while true; do
  faigate_ui_header "fusionAIze Gate Client Scenarios" "Named templates for client-specific defaults"
  render_scenarios text
  echo ""
  scenario_entries=()
  while IFS= read -r entry; do
    [ -n "$entry" ] && scenario_entries+=("$entry")
  done <<< "$(list_scenario_ids)"

  printf "  %bChoose scenario%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(pick a number or enter one scenario ID)"
  entry_index=1
  for entry in "${scenario_entries[@]}"; do
    scenario_key="${entry%%$'\t'*}"
    entry_rest="${entry#*$'\t'}"
    scenario_title="${entry_rest%%$'\t'*}"
    scenario_budget="${entry##*$'\t'}"
    printf "   %2d)  %-20s %s [%s]\n" "$entry_index" "$scenario_key" "$scenario_title" "$scenario_budget"
    entry_index=$((entry_index + 1))
  done
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ Selection: "
  if ! read -r scenario_selection; then
    exit 0
  fi
  case "$scenario_selection" in
    q|Q) exit 0 ;;
    c|C|"") return 0 2>/dev/null || exit 0 ;;
  esac
  if [[ "$scenario_selection" =~ ^[0-9]+$ ]] && (( scenario_selection >= 1 && scenario_selection <= ${#scenario_entries[@]} )); then
    chosen_entry="${scenario_entries[$((scenario_selection - 1))]}"
    scenario_id="${chosen_entry%%$'\t'*}"
  else
    scenario_id="$scenario_selection"
  fi
  echo ""
  apply_scenario "$scenario_id" "dry"
  echo ""
  printf "  %bApply mode%b\n" "$FAIGATE_UI_BOLD"
  printf "    1)  Dry-run only    Keep this as a preview\n"
  printf "    2)  Write config    Update config.yaml with this scenario\n"
  printf "    c)  Cancel\n"
  printf "    q)  Quit\n"
  printf "  ▸ [1]: "
  if ! read -r choice; then
    exit 0
  fi
  case "${choice:-1}" in
    q|Q) exit 0 ;;
    c|C|1) ;;
    2)
      scenario_client="$(scenario_client_name "$scenario_id")"
      echo ""
      apply_scenario "$scenario_id" "write"
      echo ""
      if [[ -n "$scenario_client" ]]; then
        show_next_steps "Client scenario applied." \
          "Restart + Verify next so the running gateway picks up the new ${scenario_client} profile default." \
          "Open Client Quickstarts and drill into ${scenario_client} Details to grab the exact connection settings." \
          "Provider Probe is useful when the scenario added providers you have not tested yet."
      else
        show_next_steps "Client scenario applied." \
          "Restart + Verify next so the running gateway picks up the new client profile default." \
          "Open Client Quickstarts to grab the matching client-specific connection details." \
          "Provider Probe is useful when the scenario added providers you have not tested yet."
      fi
      faigate_ui_pause
      exit 0
      ;;
  esac
done
